# Telegram Bot
BOT_TOKEN=
GROUP_ID=

# Supabase
# NOTE: For server-side bots, prefer SUPABASE_SERVICE_ROLE_KEY over SUPABASE_ANON_KEY
# to bypass Row Level Security. If using ANON_KEY, disable RLS on all tables (see schema.sql).
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Railway / Server
# Set this to your Railway public domain (e.g. my-app.up.railway.app)
# Omit for local dev — bot will fall back to polling mode.
# ADMIN_TELEGRAM_ID is no longer an env var — it lives in the Supabase settings table.
PUBLIC_DOMAIN=
PORT=3000
